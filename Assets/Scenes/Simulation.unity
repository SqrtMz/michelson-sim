  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1472540276}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Interfer\xF3metro de Michelson - Una simulaci\xF3n en Unity\n\nEn 1881
    Albert Abraham Michelson inventa un interfer\xF3metro de doble haz que bautiza
    en honor a su propio nombre como \"Interfer\xF3metro de Michelson\", este consiste
    en un haz de luz (preferiblemente paralelo) que se divide en dos partes al cruzar
    por un divisor de haz, los dos haces resultantes recorren un camino \xF3ptico
    similar, pero con un recorrido ligeramente distinto, los haces luego son reflejados
    en direcci\xF3n al divisor de haz por acci\xF3n de dos espejos, luego de esto
    los haces impactan en un detector y como resultado se observa un patr\xF3n de
    interferencia rico en informaci\xF3n y caracter\xEDsticas del mismo haz.\n\nPara
    que esta interferencia se d\xE9, se hace necesario alinear correctamente los
    dos haces de luz, usando los tornillos que se encuentran detr\xE1s del espejo
    opuesto a la fuente de luz (en el caso de la simulaci\xF3n), con lo que respecta
    al otro espejo, este es el encargado de la diferencia en el camino \xF3ptico,
    con un tornillo microm\xE9trico, se mueve hacia adelante y hacia atr\xE1s (perpendicular
    a su superficie). \n\nLos elementos usados en la pr\xE1ctica son:\n\n\t- Fuente
    de luz (un l\xE1ser, por ejemplo).\n\t- Soporte de la fuente de luz.\n\t- Lente
    focal de +5mm.\n\t- Interfer\xF3metro de Michelson.\n\t\xBB Divisor de haz\n\t\xBB
    Espejos de primera cara.\n\t\xBB Tornillo de ajuste de inclinaci\xF3n horizontal
    del espejo est\xE1tico.\n\t\xBB Tornillo de ajuste de inclinaci\xF3n vertical
    del espejo est\xE1ctico. \n\t\xBB Tornillo microm\xE9trico.\n\t\xBB Barra pivote.\n\nA
    continuaci\xF3n una lista de los controles de esta simulaci\xF3n:"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
